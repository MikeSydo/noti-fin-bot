# --- REQUIRED SETTINGS ---
# Use your real keys here for local development. Never commit this file to git!

# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_real_bot_token

# Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_real_gemini_key

# Database Connection URL
# Example: postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/noti_fin

# Fernet Key for user data encryption
# Generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_generated_fernet_key

# Notion OAuth Settings
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
NOTION_REDIRECT_URI=http://localhost:8080/auth/callback

# AWS S3 Settings (Storage for receipts)
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# --- OPTIONAL SETTINGS ---
# Environment: 'prod' (loads .env) or 'dev' (loads .env.dev)
ENV=dev
PORT=8080
DOMAIN_NAME=localhost
CHANGELOG_URL=https://github.com/MikeSydo/noti-fin-bot/blob/master/CHANGELOG.md

# Webhook Settings
WEBHOOK_URL=https://my-bot.koyeb.app
WEBHOOK_PATH=/webhook