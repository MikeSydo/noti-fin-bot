# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini AI (for receipt parsing)
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (PostgreSQL)
DB_USER=prod_user
DB_PASSWORD=prod_password
DB_NAME=prod_name
DATABASE_URL=prod_url

# Security Configuration
# Generate a new Fernet key using:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_encryption_key_here

# Notion OAuth 2.0 Configuration
NOTION_CLIENT_ID=your_notion_client_id_here
NOTION_CLIENT_SECRET=your_notion_client_secret_here
NOTION_REDIRECT_URI=https://your-domain.ngrok.io/notion-oauth-callback

# AWS S3 (for receipts)
AWS_REGION=your_aws_region
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# Caddy / Domain
DOMAIN_NAME=your-domain.com

# App Info
VERSION=n.n.n
RELEASE_NOTES_URL=https://notion.so/